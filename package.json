{
  "name": "dev-runway",
  "version": "0.1.1",
  "description": "Interactive CLI for launching frontend dev environments. Build-tool agnostic, TypeScript-first, CI-friendly.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "dev-runway": "dist/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "dist/index.d.ts",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "start": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "prepare": "husky",
    "docs:build": "scripts/build-docs.sh",
    "doc": "pnpm docs:build",
    "release": "release-it"
  },
  "dependencies": {
    "chalk": "^5.5.0",
    "commander": "^14.0.0",
    "inquirer": "^9.3.7",
    "jiti": "^2.5.1",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@release-it/conventional-changelog": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.2.3",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.33.0",
    "github-markdown-css": "^5.8.1",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "markdown-it-cli": "^1.0.0",
    "release-it": "^19.0.4",
    "tsdown": "^0.14.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.0.0",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ICEPepsiCola/dev-runway.git"
  },
  "homepage": "https://github.com/ICEPepsiCola/dev-runway#readme",
  "bugs": {
    "url": "https://github.com/ICEPepsiCola/dev-runway/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cli",
    "dev-runway",
    "frontend",
    "development",
    "environment",
    "dev-server",
    "vite",
    "webpack",
    "typescript",
    "interactive"
  ],
  "author": "cola",
  "license": "ISC",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
